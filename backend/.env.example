# Copie ce fichier en ".env" et renseigne tes propres valeurs.

# Chaîne de connexion MongoDB (Atlas ou locale)
# Exemple local     : mongodb://127.0.0.1:27017/unifood_maintenance
# Exemple MongoDB Atlas : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/unifood_maintenance
MONGO_URI=mongodb+srv://unifood_admin:UNIFOOD1234@cluster0.r9wqbtf.mongodb.net/unifood_maintenance?retryWrites=true&w=majority

# Port du serveur API
PORT=4000

# Clé secrète utilisée pour signer les jetons de connexion (JWT)
# Mets une longue chaîne aléatoire en production
JWT_SECRET=change_this_secret_key_unifood_togo_2026

# Durée de validité du jeton de connexion
JWT_EXPIRES_IN=12h

# Nom affiché de l'usine sur les documents générés (PDF/Word/Excel)
COMPANY_NAME=UNIFOOD TOGO
COMPANY_SUBTITLE=Usine de fabrication de bonbons - Confiserie
